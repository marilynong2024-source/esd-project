# Copy to `.env` in the project root (same folder as docker-compose.yml).
# Docker Compose loads this file automatically for ${VAR} substitution.
# Do not commit `.env` if it contains secrets (SMU API key, etc.).

# ---------------------------------------------------------------------------
# Optional: skip Flight/Hotel HTTP checks on POST /booking (default is to validate)
# SKIP_CATALOG_VALIDATION=false

# ---------------------------------------------------------------------------
# MySQL (Booking service) — defaults match docker-compose booking-db service
# ---------------------------------------------------------------------------
BOOKING_DB_URL=mysql+pymysql://travel_user:travel_pass@booking-db:3306/travel_booking

# Optional: override MySQL container credentials (must match booking-db service)
# MYSQL_ROOT_PASSWORD=root
# MYSQL_DATABASE=travel_booking
# MYSQL_USER=travel_user
# MYSQL_PASSWORD=travel_pass

# ---------------------------------------------------------------------------
# OutSystems — Traveller Profile (teammate-owned REST). Routes + Create body: travellerprofile/outsystems_client.py
# ---------------------------------------------------------------------------
# TRAVELLER_PROFILE_BASE_URL=https://personal-zhhppbon.outsystemscloud.com/TravellerProfileService/rest/TravellerProfileAPI

TRAVELLER_PROFILE_BASE_URL=
# If true, a missing/invalid profile ID fails the booking when URL is set
TRAVELLER_PROFILE_REQUIRED=false

# ---------------------------------------------------------------------------
# External FX (optional) — exchangerate.host; satisfies “external API” in demo
# ---------------------------------------------------------------------------
FX_API_ENABLED=false
# FX_API_URL=https://api.exchangerate.host/latest?base=SGD&symbols=USD,EUR

# ---------------------------------------------------------------------------
# SMU Lab Utilities — SendEmail (Notification service after RabbitMQ event)
# ---------------------------------------------------------------------------
SMU_NOTIFICATION_ENABLED=false
SMU_NOTIFICATION_BASE_URL=https://smuedu-dev.outsystemsenterprise.com/SMULab_Notification/rest/Notification
SMU_NOTIFY_EMAIL_TO=
SMU_NOTIFICATION_AUTH_HEADER=Authorization
SMU_NOTIFICATION_AUTH_VALUE=

# ---------------------------------------------------------------------------
# Twilio — SMS (Notification service after RabbitMQ booking.cancelled)
# Trial: verify TWILIO_TO_NUMBER in Twilio console. Do not commit real tokens.
# ---------------------------------------------------------------------------
TWILIO_ENABLED=false
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+15551234567
# TWILIO_TO_NUMBER=+6591234567
